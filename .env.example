# Non-secret config lives in config/<RISK_ENV>.toml (committed). This file holds
# only secrets and the few runtime overrides - it is gitignored, never committed.

# Which environment to load: config/local.toml (default) or config/demo.toml
RISK_ENV=local

# Exchange API credentials. Required only when the selected env uses
# execution.backend = "exchange". Use demo/testnet keys - never real-account
# keys, and never commit real values.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# Optional per-container overrides (docker-compose sets these for the replica).
# When unset, the value from the TOML is used.
# REPLICA_MODE=false
# METRICS_PORT=9090

# Optional path anchors. Relative paths in the TOML resolve against these; unset
# defaults to the repo root (APP_HOME) and <APP_HOME>/data (DATA_DIR). Set them
# (or use absolute TOML paths) for containerized / mounted-volume deployments.
# APP_HOME=/opt/risk-engine
# DATA_DIR=/var/lib/risk-engine
